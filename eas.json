{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_KEY": "[PASTE_YOUR_GEMINI_API_KEY_HERE]"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_KEY": "[PASTE_YOUR_GEMINI_API_KEY_HERE]"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
